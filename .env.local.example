# =====================================================================
# Quest Club Web · variables de entorno
# Copia este archivo a `.env.local` y rellena con valores reales.
# `.env.local` está ignorado por git (no se sube al repo).
# =====================================================================

# ---------- Supabase ----------
# Settings → API → Publishable and secret API keys (nuevo naming, no legacy)
# Project URL: https://<project_ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ---------- Resend ----------
# resend.com → API Keys
# Sender debe estar en un dominio verificado (questclub.app tras DNS setup)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Quest Club <hola@questclub.app>

# ---------- Cloudflare Turnstile ----------
# dash.cloudflare.com → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------- Upstash Redis (rate limiting) ----------
# console.upstash.com → Redis → Create Database (region: eu-west-1)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- App ----------
# URL pública. Solo se usa en producción (canonicaliza al dominio).
# En dev se ignora — la API y la UI usan el origen real del request.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Counter inicial ----------
# Base que se SUMA al total real de la waitlist al renderizar.
# Sirve para evitar "0 apuntados" en lanzamiento. Cuando los reales
# sean visibles (>500 confirmaciones) bájalo a 0 sin redeploy.
NEXT_PUBLIC_COUNTER_BASE=1001
